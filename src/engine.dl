// sgiandubh decode — the semiring combine, as the REFERENCE SPEC (this file is no longer compiled). The runtime decode
// is this program ported to C++ in `src/rosetta_package.h` (rosetta::decode_facts), verified identical to the former
// Soufflé build (max |Δlogprob| ~3e-6, float32↔float64). Soufflé is retired from sgiandubh; this stays as the
// certificate's formal statement.
//
// Input facts (from the extracted expert package): the candidate set + each residual block's contribution.
// Output: decide = argmax candidate (the (max,+) tropical decode). Swap the ⊕ to log-sum-exp for the full distribution
// / confidence — the host does that softmax over `logit` for OpenAI `logprobs`.
.decl candidate(t:number)
.input candidate
.decl contrib(block:symbol, t:number, w:float)
.input contrib

.decl logit(t:number, s:float)
logit(T, S) :- candidate(T), S = sum W : { contrib(_, T, W) }.   // ⊗ = + : block contributions sum to the logit
.output logit                                                    // per-candidate logits → host-side softmax (logprobs)

.decl decide(t:number)
decide(T) :- logit(T, S), S = max S2 : { logit(_, S2) }.          // ⊕ = max : the greedy (T=0) decode
.output decide
